---
import BaseLayout from '../layouts/BaseLayout.astro';

type Surface = 'dark' | 'light';

const content = {
  meta: {
    title: 'LexIT Executive Governance | V2',
    description:
      'Executive Governance für NIS2, DORA, AI Act und DSGVO. Klare Verantwortung, belastbare Nachweise, Entscheidungen mit Substanz.',
  },
  nav: {
    ariaLabel: 'Hauptnavigation',
    brand: {
      href: '/',
      srLabel: 'LexIT Startseite',
      alt: 'LexIT Executive Governance Logo',
      logos: {
        lightOnDark: '/Lexit_X_logo_dark_bg.png',
        darkOnLight: '/Lexit_X_logo_only.png',
      },
    },
    links: [
      { href: '#leistungen', label: 'Leistungen' },
      { href: '#ansatz', label: 'Ansatz' },
      { href: '#ueber', label: 'Über LexIT' },
      { href: '#faq', label: 'FAQ' },
    ],
    cta: {
      href: '/v2/kontakt',
      label: 'Kontakt',
    },
  },
  hero: {
    id: 'hero',
    logoSurface: 'dark' as Surface,
    logoAlt: 'LexIT Brandmarke',
    kicker: 'Executive Governance for Regulated IT',
    title: 'Regulatorik verlangt Führung.',
    description:
      'LexIT bringt Ordnung in NIS2, DORA, AI Act und DSGVO. Sie erhalten klare Verantwortung, belastbare Nachweise und ein Setup für Managemententscheidungen.',
    primaryCta: { href: '/v2/kontakt', label: 'Vertrauliches Erstgespräch' },
    secondaryCta: { href: '#leistungen', label: 'Leistungsfelder prüfen' },
    trustChips: [
      '15+ Jahre Konzernpraxis',
      'ISO 27001, ISO 9001, ISO 14001',
      'Legal 500 GC Powerlist 2022 & 2024',
      'Fokus: Österreich und Deutschland',
    ],
  },
  sectionHeaders: {
    problems: {
      id: 'problemfelder',
      kicker: 'Ausgangslage',
      title: 'Wo Führung unter Druck gerät',
      text: 'Wenn Rollen, Nachweise und Prioritäten auseinanderlaufen, verliert das Management Zeit, Kontrolle und Entscheidungstempo.',
    },
    solutions: {
      id: 'leistungen',
      kicker: 'Leistungen',
      title: 'Drei Felder für belastbare Steuerung',
      text: 'LexIT ordnet Regulierung, Verantwortung und Betrieb in ein steuerbares Modell.',
    },
    process: {
      id: 'ansatz',
      kicker: 'Vorgehen',
      title: 'So entsteht Steuerungsfähigkeit',
      text: 'Wir schaffen Lagebild, Verantwortung und Nachweislogik, damit Geschäftsführung und IT-Leitung Entscheidungen tragen können.',
    },
    stories: {
      id: 'ueber',
      kicker: 'Profil',
      title: 'Führungserfahrung mit Umsetzungstiefe',
      text: 'Matthias König verbindet juristische Präzision mit Verantwortung für Compliance, IT und Informationssicherheit.',
    },
    faq: {
      id: 'faq',
      kicker: 'FAQ',
      title: 'Fragen vor dem Mandat',
      text: 'Kurz zu Ablauf, Umfang und Zusammenarbeit.',
    },
  },
  problemCards: [
    {
      title: 'Vorgaben treffen auf Betrieb',
      tag: 'Komplexität',
      text: 'NIS2, DORA, AI Act und DSGVO greifen zugleich in Organisation, IT und Berichtspflichten ein.',
      impact: 'Die Leitung vertagt Entscheidungen, Fachbereiche arbeiten in getrennten Spuren.',
    },
    {
      title: 'Nachweise bleiben fragmentiert',
      tag: 'Audit-Druck',
      text: 'Teams sammeln Dokumente, doch oft fehlt eine Struktur, die Verantwortung, Fristen und Evidenz zusammenführt.',
      impact: 'IT, Legal und Compliance verlieren Zeit in Abstimmung, Prüfungen und Rückfragen.',
    },
    {
      title: 'Kritische Entscheidungen haben keinen Pfad',
      tag: 'Verantwortung',
      text: 'Wenn Rollen und Eskalationspfade fehlen, bleibt offen, wer entscheidet, eskaliert und liefert.',
      impact: 'Maßnahmen verlieren Priorität und Wirkung.',
    },
  ],
  solutionCards: [
    {
      title: 'IT-Compliance',
      href: '/v2/leistungen/it-compliance',
      description:
        'LexIT ordnet Pflichten, setzt Prioritäten und überführt Vorgaben in einen belastbaren Arbeitsplan.',
      bullets: [
        'NIS2, DORA, AI Act und DSGVO priorisieren',
        'Pflichten in bestehende Abläufe einbauen',
        'Nachweise für Audits und Prüfungen aufsetzen',
      ],
      linkLabel: 'Mehr zu IT-Compliance',
    },
    {
      title: 'IT-Governance',
      href: '/v2/leistungen/it-governance',
      description:
        'LexIT legt fest, wer entscheidet, wer Risiken trägt und welche Kennzahlen auf Leitungsebene zählen.',
      bullets: [
        'Rollen und Eskalationswege festlegen',
        'Risiken mit Managemententscheidungen verknüpfen',
        'Governance-Strukturen für Audits aufsetzen',
      ],
      linkLabel: 'Mehr zu IT-Governance',
    },
    {
      title: 'Produktdesign für IT-Services',
      href: '/v2/leistungen/produktdesign',
      description:
        'LexIT schärft IT-Services, bis Scope, SLA, Preis und Vertragslogik sauber greifen.',
      bullets: [
        'Nutzen und Zielbild für Kunden schärfen',
        'Servicearchitektur mit SLA verbinden',
        'Leistungsumfang für Vertrieb und Betrieb klären',
      ],
      linkLabel: 'Mehr zu Produktdesign',
    },
  ],
  howSteps: [
    {
      step: '01',
      title: 'Lagebild und Priorisierung',
      text: 'Wir prüfen Anforderungen, Risiken, Rollen und Reifegrad.',
    },
    {
      step: '02',
      title: 'Governance-Design',
      text: 'Wir legen Entscheidungen, Schnittstellen und Verantwortlichkeiten fest.',
    },
    {
      step: '03',
      title: 'Umsetzung im Betrieb',
      text: 'Wir bauen Maßnahmen, Routinen und Nachweise in den Betrieb ein.',
    },
    {
      step: '04',
      title: 'Stabilisierung und Weiterentwicklung',
      text: 'Wir prüfen Wirkung, schließen Lücken und schärfen das Setup nach.',
    },
  ],
  featureStories: [
    {
      title: 'Profil',
      lead:
        'Matthias König verbindet juristische Ausbildung mit Führungsverantwortung in IT, Compliance und Informationssicherheit.',
      bullets: [
        'Manager Legal & Compliance in internationalem IT-Umfeld',
        'Interim-CISO mit Verantwortung für Informationssicherheit',
        'ESG-Programme und ISO-Zertifizierungen aufgebaut',
      ],
      frame: {
        eyebrow: 'Leadership Lens',
        headline: 'Legal x Compliance x IT',
        caption: 'Recht, Compliance und IT greifen in einer Verantwortung zusammen.',
      },
    },
    {
      title: 'Erfahrung',
      lead:
        'Er kennt Strategie, Aufbau und Umsetzung aus der Konzernpraxis.',
      bullets: [
        '10+ Jahre Konzern: Legal, Compliance, IT-Governance, CISO',
        'ISO 27001, ISO 9001, ISO 14001: Implementierung und Audits',
        'Service Level Management und ITIL-Implementierung',
      ],
      frame: {
        eyebrow: 'Execution Snapshot',
        headline: 'Audit-Ready Operations',
        caption: 'Audits, Rollen und Nachweise greifen im Betrieb ineinander.',
      },
    },
    {
      title: 'Qualifikationen & Auszeichnungen',
      lead:
        'Seine Ausbildung und Auszeichnungen geben Geschäftsführung und IT-Leitung eine belastbare Grundlage für Entscheidungen.',
      bullets: [
        'Mag. iur. und M.A. IT-Law and Management',
        'ITIL v3 Expert und ITIL 4 Managing Professional',
        'Certified Compliance Officer (Austrian Standards)',
        'Dozent an Donau-Universität Krems und FH Burgenland',
        'Legal 500 GC Powerlist: Austria 2022 und 2024',
      ],
      frame: {
        eyebrow: 'Proof Layer',
        headline: 'Board-Level Credibility',
        caption: 'Fachliche Tiefe trifft auf Führungserfahrung.',
      },
    },
  ],
  faq: [
    {
      question: 'Für wen ist LexIT der richtige Partner?',
      answer:
        'Für Geschäftsführung, IT-Leitung und Compliance-Teams, die Verantwortung klären und Regulierung im Betrieb verankern müssen.',
    },
    {
      question: 'Wie startet ein gemeinsames Projekt?',
      answer:
        'Wir starten mit einem Lagebild. Danach priorisieren wir Themen, legen Verantwortung fest und bestimmen den ersten Umsetzungsblock.',
    },
    {
      question: 'Werden nur Konzernstrukturen unterstützt?',
      answer:
        'Nein. LexIT arbeitet mit mittelständischen Unternehmen und mit Konzernstrukturen.',
    },
    {
      question: 'In welchen Regionen arbeitet LexIT?',
      answer:
        'Der Schwerpunkt liegt auf Österreich und Deutschland, vor Ort und remote.',
    },
  ],
  finalCta: {
    id: 'kontakt',
    kicker: 'Nächster Schritt',
    title: 'Sie brauchen Steuerung statt Dauerreaktion.',
    text: 'LexIT bringt Erfahrung aus ISO-Zertifizierungen, ESG und IT-Governance in Ihr Vorhaben. Sie gewinnen klare Verantwortung, belastbare Nachweise und ein Management-Setup für Entscheidungen.',
    note:
      'Für Geschäftsführung, IT-Leitung und Compliance mit hohem Regulierungsdruck.',
    primaryCta: { href: '/v2/kontakt', label: 'Vertrauliches Gespräch anfragen' },
    secondaryCta: { href: '/v2/impressum', label: 'Impressum' },
  },
  footer: {
    company: 'LexIT Executive Governance',
    location: 'Graz, Steiermark, Österreich',
    phone: { href: 'tel:+436606088762', label: '+43 660 60 88 762' },
    legalLinks: [
      { href: '/v2/impressum', label: 'Impressum' },
      { href: '/v2/datenschutz', label: 'Datenschutz' },
    ],
    copyright: '© LexIT Executive Governance',
  },
};

const logoForSurface = (surface: Surface) =>
  surface === 'dark' ? content.nav.brand.logos.lightOnDark : content.nav.brand.logos.darkOnLight;

const heroLogo = logoForSurface(content.hero.logoSurface);
const heroWords = content.hero.title.split(' ');
---

<BaseLayout title={content.meta.title} description={content.meta.description}>
  <main class="v2-page" id="top">
    <div class="v2-hero-bg" aria-hidden="true">
      <div class="v2-geometric-shape" style="--shape-width: 600px; --shape-height: 140px; --shape-delay: 0.2s; --shape-rotate: 12deg; --shape-color: rgba(99, 102, 241, 0.3); left: -8%; top: 12%;">
        <span class="v2-geometric-shape-core"></span>
      </div>
      <div class="v2-geometric-shape" style="--shape-width: 500px; --shape-height: 120px; --shape-delay: 0.45s; --shape-rotate: -15deg; --shape-color: rgba(244, 63, 94, 0.28); right: -4%; top: 68%;">
        <span class="v2-geometric-shape-core"></span>
      </div>
      <div class="v2-geometric-shape" style="--shape-width: 340px; --shape-height: 82px; --shape-delay: 0.35s; --shape-rotate: -8deg; --shape-color: rgba(139, 92, 246, 0.26); left: 4%; bottom: 7%;">
        <span class="v2-geometric-shape-core"></span>
      </div>
      <div class="v2-geometric-shape" style="--shape-width: 220px; --shape-height: 62px; --shape-delay: 0.55s; --shape-rotate: 20deg; --shape-color: rgba(245, 158, 11, 0.24); right: 18%; top: 14%;">
        <span class="v2-geometric-shape-core"></span>
      </div>
      <div class="v2-geometric-shape" style="--shape-width: 160px; --shape-height: 44px; --shape-delay: 0.7s; --shape-rotate: -25deg; --shape-color: rgba(6, 182, 212, 0.24); left: 20%; top: 8%;">
        <span class="v2-geometric-shape-core"></span>
      </div>
    </div>

    <header class="v2-nav-wrap" data-reveal>
      <nav class="v2-nav" aria-label={content.nav.ariaLabel}>
        <a href={content.nav.brand.href} class="v2-brand-link" aria-label={content.nav.brand.srLabel}>
          <img
            src="/lexit_ExG_logo_only_white.png"
            alt={content.nav.brand.alt}
            width="6833"
            height="2878"
            class="v2-nav-logo"
            loading="eager"
            decoding="async"
          />
        </a>

        <ul class="v2-nav-links">
          {content.nav.links.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>

        <a class="v2-btn v2-btn-solid v2-nav-cta" href={content.nav.cta.href}>
          {content.nav.cta.label}
        </a>
      </nav>
    </header>

    <section id={content.hero.id} class="v2-hero">
      <div class="v2-shell v2-hero-inner">
        <div class="v2-hero-copy" data-reveal>
          <p class="v2-kicker">{content.hero.kicker}</p>

          <h1 class="v2-hero-title" aria-label={content.hero.title}>
            {heroWords.map((word, index) => (
              <span class={`v2-hero-word v2-word-${(index % 10) + 1}`}>{word}</span>
            ))}
          </h1>

          <p class="v2-hero-lead">{content.hero.description}</p>

          <div class="v2-hero-actions">
            <a href={content.hero.primaryCta.href} class="v2-btn v2-btn-solid">
              {content.hero.primaryCta.label}
            </a>
            <a href={content.hero.secondaryCta.href} class="v2-btn v2-btn-ghost">
              {content.hero.secondaryCta.label}
            </a>
          </div>

          <ul class="v2-chip-list">
            {content.hero.trustChips.map((chip) => (
              <li class="v2-chip">{chip}</li>
            ))}
          </ul>
        </div>

        <aside class="v2-hero-visual" aria-hidden="true" data-reveal>
          <div class="v2-logo-fluid">
            <div class="v2-logo-orb">
              <img
                src={heroLogo}
                alt={content.hero.logoAlt}
                width="1640"
                height="701"
                class="v2-hero-logo"
                loading="eager"
                decoding="async"
              />
              <span class="v2-orbit v2-orbit-a"></span>
              <span class="v2-orbit v2-orbit-b"></span>
              <span class="v2-orbit v2-orbit-c"></span>
            </div>
          </div>
        </aside>

      </div>
    </section>

    <section id={content.sectionHeaders.problems.id} class="v2-section">
      <div class="v2-shell">
        <header class="v2-section-head" data-reveal>
          <p class="v2-kicker">{content.sectionHeaders.problems.kicker}</p>
          <h2>{content.sectionHeaders.problems.title}</h2>
          <p>{content.sectionHeaders.problems.text}</p>
        </header>

        <div class="v2-grid v2-grid-3">
          {content.problemCards.map((card) => (
            <article class="v2-card v2-problem-card" data-reveal>
              <p class="v2-card-tag">{card.tag}</p>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <p class="v2-impact">{card.impact}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id={content.sectionHeaders.solutions.id} class="v2-section v2-section-tint">
      <div class="v2-shell">
        <header class="v2-section-head" data-reveal>
          <p class="v2-kicker">{content.sectionHeaders.solutions.kicker}</p>
          <h2>{content.sectionHeaders.solutions.title}</h2>
          <p>{content.sectionHeaders.solutions.text}</p>
        </header>

        <div class="v2-grid v2-grid-3">
          {content.solutionCards.map((card) => (
            <article class="v2-card v2-solution-card" data-reveal>
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <ul>
                {card.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
              <a href={card.href} class="v2-inline-link">
                {card.linkLabel}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id={content.sectionHeaders.process.id} class="v2-section">
      <div class="v2-shell">
        <header class="v2-section-head" data-reveal>
          <p class="v2-kicker">{content.sectionHeaders.process.kicker}</p>
          <h2>{content.sectionHeaders.process.title}</h2>
          <p>{content.sectionHeaders.process.text}</p>
        </header>

        <ol class="v2-steps">
          {content.howSteps.map((step) => (
            <li class="v2-step" data-reveal>
              <p class="v2-step-no">{step.step}</p>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id={content.sectionHeaders.stories.id} class="v2-section v2-section-tint">
      <div class="v2-shell">
        <header class="v2-section-head" data-reveal>
          <p class="v2-kicker">{content.sectionHeaders.stories.kicker}</p>
          <h2>{content.sectionHeaders.stories.title}</h2>
          <p>{content.sectionHeaders.stories.text}</p>
        </header>

        <div class="v2-story-list">
          {content.featureStories.map((story) => (
            <article class="v2-story" data-reveal>
              <div class="v2-story-frame" aria-hidden="true">
                <p class="v2-frame-eyebrow">{story.frame.eyebrow}</p>
                <h3 class="v2-frame-headline">{story.frame.headline}</h3>
                <p class="v2-frame-caption">{story.frame.caption}</p>
              </div>

              <div class="v2-story-copy">
                <h3>{story.title}</h3>
                <p class="v2-story-lead">{story.lead}</p>
                <ul>
                  {story.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id={content.sectionHeaders.faq.id} class="v2-section">
      <div class="v2-shell v2-faq-shell">
        <header class="v2-section-head" data-reveal>
          <p class="v2-kicker">{content.sectionHeaders.faq.kicker}</p>
          <h2>{content.sectionHeaders.faq.title}</h2>
          <p>{content.sectionHeaders.faq.text}</p>
        </header>

        <div class="v2-faq-list">
          {content.faq.map((item, index) => (
            <details class="v2-faq-item" open={index === 0} data-reveal>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section id={content.finalCta.id} class="v2-section v2-final">
      <div class="v2-shell">
        <article class="v2-final-card" data-reveal>
          <p class="v2-kicker">{content.finalCta.kicker}</p>
          <h2>{content.finalCta.title}</h2>
          <p class="v2-final-text">{content.finalCta.text}</p>
          <p class="v2-final-note">{content.finalCta.note}</p>
          <div class="v2-hero-actions">
            <a href={content.finalCta.primaryCta.href} class="v2-btn v2-btn-solid">
              {content.finalCta.primaryCta.label}
            </a>
            <a href={content.finalCta.secondaryCta.href} class="v2-btn v2-btn-ghost">
              {content.finalCta.secondaryCta.label}
            </a>
          </div>
        </article>
      </div>
    </section>

    <footer class="v2-footer">
      <div class="v2-shell v2-footer-grid">
        <div class="v2-footer-block" data-reveal>
          <img
            src={content.nav.brand.logos.lightOnDark}
            alt={content.nav.brand.alt}
            width="1640"
            height="701"
            class="v2-footer-logo"
            loading="lazy"
            decoding="async"
          />
          <p>{content.footer.company}</p>
          <p>{content.footer.location}</p>
        </div>

        <div class="v2-footer-block" data-reveal>
          <a class="v2-inline-link" href={content.footer.phone.href}>
            {content.footer.phone.label}
          </a>
          <nav aria-label="Rechtliches">
            <ul class="v2-footer-legal">
              {content.footer.legalLinks.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </nav>
          <p>{content.footer.copyright}</p>
        </div>
      </div>
    </footer>
  </main>

  <script>
    const root = document.documentElement;
    const validPresets = new Set(['ultra', 'balanced', 'showcase']);
    const params = new URLSearchParams(window.location.search);
    const urlPreset = params.get('motion');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const applyMotionPreset = () => {
      if (reducedMotion.matches) {
        root.dataset.motion = 'ultra';
        return;
      }
      root.dataset.motion = validPresets.has(urlPreset || '') ? urlPreset : 'balanced';
    };

    applyMotionPreset();

    if (typeof reducedMotion.addEventListener === 'function') {
      reducedMotion.addEventListener('change', applyMotionPreset);
    }

    const heroFluid = document.querySelector('.v2-logo-fluid');
    let wobbleOffset = 0;
    let wobbleVelocity = 0;
    let wobbleRaf = 0;
    let lastScrollY = window.scrollY;

    const resetHeroWobble = () => {
      wobbleOffset = 0;
      wobbleVelocity = 0;

      if (wobbleRaf) {
        cancelAnimationFrame(wobbleRaf);
        wobbleRaf = 0;
      }

      if (heroFluid instanceof HTMLElement) {
        heroFluid.style.setProperty('--hero-scroll-bob', '0px');
      }
    };

    const runHeroWobble = () => {
      const spring = 0.025;
      const damping = 0.85;

      wobbleVelocity += -wobbleOffset * spring;
      wobbleOffset += wobbleVelocity;
      wobbleVelocity *= damping;

      if (heroFluid instanceof HTMLElement) {
        heroFluid.style.setProperty('--hero-scroll-bob', `${wobbleOffset.toFixed(2)}px`);
      }

      const motionSettled = Math.abs(wobbleOffset) < 0.06 && Math.abs(wobbleVelocity) < 0.06;
      if (motionSettled) {
        resetHeroWobble();
        return;
      }

      wobbleRaf = requestAnimationFrame(runHeroWobble);
    };

    const nudgeHeroWobble = () => {
      if (!(heroFluid instanceof HTMLElement) || reducedMotion.matches) {
        return;
      }

      const currentScrollY = window.scrollY;
      const scrollDelta = currentScrollY - lastScrollY;
      lastScrollY = currentScrollY;

      const impulse = Math.max(Math.min(scrollDelta * 0.24, 8), -8);
      wobbleVelocity += impulse;

      if (!wobbleRaf) {
        wobbleRaf = requestAnimationFrame(runHeroWobble);
      }
    };

    const heroSection = document.querySelector('.v2-hero');
    const heroBg = document.querySelector('.v2-hero-bg');
    const heroShapes = [...document.querySelectorAll('.v2-geometric-shape')];
    const shapeProfiles = heroShapes.map((shape, index) => ({
      shape,
      seedX: 0.21 + Math.random() * 0.42,
      seedY: 0.37 + Math.random() * 0.5,
      seedR: 0.13 + Math.random() * 0.41,
      ampX: 2.8 + Math.random() * 3.2,
      ampY: 2.0 + Math.random() * 2.9,
      ampR: 0.22 + Math.random() * 0.58,
      phase: index * 0.83,
      baseRotate: parseFloat(getComputedStyle(shape).getPropertyValue('--shape-rotate')) || 0,
    }));
    let heroDriftRaf = 0;
    let heroScrollState = window.scrollY;
    let heroShapeLag = 0;

    const setShapeFloat = () => {
      if (reducedMotion.matches || !heroSection) {
        return;
      }

      const heroRect = heroSection.getBoundingClientRect();
      const heroHeight = Math.max(heroSection.offsetHeight, 1);
      const sectionOffset = Math.max(-24, Math.min(24, ((-heroRect.top) / heroHeight - 0.5) * 32));
      heroShapeLag += (sectionOffset - heroShapeLag) * 0.16;
      const currentScroll = window.scrollY;
      const scrollDelta = currentScroll - heroScrollState;
      heroScrollState = currentScroll;
      if (Math.abs(scrollDelta) > 0.2) {
        heroShapeLag = Math.max(-24, Math.min(24, heroShapeLag + scrollDelta * 0.06));
      }
      const bgOffset = (heroShapeLag * 0.35).toFixed(2);
      const t = performance.now() / 1000;

      if (heroBg instanceof HTMLElement) {
        heroBg.style.setProperty('--hero-bg-scroll', `${bgOffset}px`);
      }

      shapeProfiles.forEach((entry, index) => {
        const waveX = Math.sin(t * entry.seedX + entry.phase) * entry.ampX + Math.sin(t * (entry.seedX * 2.9) + entry.phase * 2) * 0.8;
        const waveY = Math.cos(t * entry.seedY + entry.phase * 1.2) * entry.ampY + Math.cos(t * (entry.seedY * 2.1) + 1.9) * 0.7;
        const waveR = Math.sin(t * entry.seedR + entry.phase * 1.1) * entry.ampR;

        if (entry.shape instanceof HTMLElement) {
          const lagOffset = (heroShapeLag * (0.88 - index * 0.08)).toFixed(2);
          entry.shape.style.setProperty('--shape-parallax-y', `${lagOffset}px`);
          entry.shape.style.setProperty('--shape-scroll-offset', `${(heroShapeLag * 0.2).toFixed(2)}px`);
          entry.shape.style.setProperty('--shape-jitter-x', `${waveX.toFixed(2)}px`);
          entry.shape.style.setProperty('--shape-jitter-y', `${waveY.toFixed(2)}px`);
          entry.shape.style.setProperty('--shape-jitter-rotate', `${(waveR + entry.baseRotate).toFixed(3)}deg`);
        }
      });
    };

    const stepShapeDrift = () => {
      setShapeFloat();
      heroDriftRaf = requestAnimationFrame(stepShapeDrift);
    };

    const startHeroShapeDrift = () => {
      if (reducedMotion.matches || heroDriftRaf) {
        return;
      }
      heroDriftRaf = requestAnimationFrame(stepShapeDrift);
    };

    const stopHeroShapeDrift = () => {
      if (heroDriftRaf) {
        cancelAnimationFrame(heroDriftRaf);
        heroDriftRaf = 0;
      }
    };

    const cardOrbitTargets = [...document.querySelectorAll('.v2-card')];
    const cardOrbitSpeed = 1.08;
    const cardHoverOrbitDuration = 940;
    const cardRowTopTolerance = 14;
    let cardOrbitRows = [];
    const cardHoverOrbitRaf = new WeakMap();

    const getCardOrbitPoint = (width, height, progress) => {
      const perimeter = width * 2 + height * 2;

      if (!width || !height || !perimeter) {
        return { x: width / 2 || 0, y: height || 0 };
      }

      const loopedProgress = ((progress % 1) + 1) % 1;
      let distance = loopedProgress * perimeter;
      let x = width / 2;
      let y = height;

      if (distance <= width / 2) {
        x = width / 2 - distance;
      } else if (distance <= width / 2 + height) {
        distance -= width / 2;
        x = 0;
        y = height - distance;
      } else if (distance <= width / 2 + height + width) {
        distance -= width / 2 + height;
        x = distance;
        y = 0;
      } else if (distance <= width / 2 + height + width + height) {
        distance -= width / 2 + height + width;
        x = width;
        y = distance;
      } else {
        distance -= width / 2 + height + width + height;
        x = width - distance;
        y = height;
      }

      return { x, y };
    };

    const buildCardOrbitRows = () => {
      if (!cardOrbitTargets.length) {
        cardOrbitRows = [];
        return;
      }

      const nextRows = [];
      const currentScrollY = window.scrollY;

      cardOrbitTargets.forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        const rect = card.getBoundingClientRect();
        const top = rect.top + currentScrollY;
        const bottom = top + rect.height;

        let row = nextRows.find((entry) => Math.abs(entry.top - top) <= cardRowTopTolerance);

        if (!row) {
          row = { top, bottom, cards: [] };
          nextRows.push(row);
        } else {
          row.top = Math.min(row.top, top);
          row.bottom = Math.max(row.bottom, bottom);
        }

        row.cards.push(card);
      });

      cardOrbitRows = nextRows.sort((a, b) => a.top - b.top);
    };

    const setCardOrbitPosition = (card, x, y, progress) => {
      card.style.setProperty('--card-orbit-x', `${x.toFixed(2)}%`);
      card.style.setProperty('--card-orbit-y', `${y.toFixed(2)}%`);
      card.style.setProperty('--card-orbit-progress', progress.toFixed(4));
      // Align conic sweep origin with the perimeter path origin (bottom center).
      card.style.setProperty('--card-orbit-angle', `${(progress * 360 + 180).toFixed(2)}deg`);
    };

    const resetCardOrbits = () => {
      cardOrbitTargets.forEach((card) => {
        if (card instanceof HTMLElement) {
          setCardOrbitPosition(card, 50, 100, 0);
          card.style.setProperty('--card-hover-sweep', '0deg');
        }
      });
    };

    const stopCardHoverOrbit = (card) => {
      const hoverRaf = cardHoverOrbitRaf.get(card);
      if (hoverRaf) {
        cancelAnimationFrame(hoverRaf);
        cardHoverOrbitRaf.delete(card);
      }

      if (card instanceof HTMLElement) {
        card.style.setProperty('--card-hover-sweep', '0deg');
      }
    };

    const startCardHoverOrbit = (card) => {
      if (!(card instanceof HTMLElement) || reducedMotion.matches) {
        return;
      }

      stopCardHoverOrbit(card);

      const startTime = performance.now();
      card.style.setProperty('--card-hover-sweep', '12deg');

      const stepHoverOrbit = (now) => {
        const elapsed = now - startTime;
        const timelineProgress = Math.min(elapsed / cardHoverOrbitDuration, 1);
        const eased = timelineProgress < 0.5
          ? 2 * timelineProgress * timelineProgress
          : 1 - Math.pow(-2 * timelineProgress + 2, 2) / 2;
        const sweep = 12 + eased * 348;

        card.style.setProperty('--card-hover-sweep', `${Math.min(sweep, 360).toFixed(2)}deg`);

        if (timelineProgress < 1 && card.matches(':hover, :focus-within')) {
          const nextFrame = requestAnimationFrame(stepHoverOrbit);
          cardHoverOrbitRaf.set(card, nextFrame);
          return;
        }

        if (card.matches(':hover, :focus-within')) {
          card.style.setProperty('--card-hover-sweep', '360deg');
          cardHoverOrbitRaf.delete(card);
          return;
        }

        stopCardHoverOrbit(card);
      };

      const firstFrame = requestAnimationFrame(stepHoverOrbit);
      cardHoverOrbitRaf.set(card, firstFrame);
    };

    const syncCardOrbits = () => {
      if (!cardOrbitTargets.length) {
        return;
      }

      if (reducedMotion.matches) {
        resetCardOrbits();
        return;
      }

      if (!cardOrbitRows.length) {
        buildCardOrbitRows();
      }

      const viewportHeight = window.innerHeight;

      cardOrbitRows.forEach((row) => {
        const rowStart = row.top - viewportHeight * 0.88;
        const rowEnd = row.bottom - viewportHeight * 0.2;
        const rowWindow = Math.max(rowEnd - rowStart, 1);
        const rowBaseProgress = Math.min(Math.max((window.scrollY - rowStart) / rowWindow, 0), 1);
        const rowProgress = Math.min(rowBaseProgress * cardOrbitSpeed, 1);

        row.cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) {
            return;
          }

          const width = card.offsetWidth;
          const height = card.offsetHeight;
          if (!width || !height) {
            setCardOrbitPosition(card, 50, 100, rowProgress);
            return;
          }

          const { x, y } = getCardOrbitPoint(width, height, rowProgress);
          setCardOrbitPosition(card, (x / width) * 100, (y / height) * 100, rowProgress);
        });
      });
    };

    cardOrbitTargets.forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      card.addEventListener('pointerenter', () => startCardHoverOrbit(card));
      card.addEventListener('focusin', () => startCardHoverOrbit(card));
      card.addEventListener('pointerleave', () => stopCardHoverOrbit(card));
      card.addEventListener('focusout', () => {
        if (!card.matches(':focus-within')) {
          stopCardHoverOrbit(card);
        }
      });
    });

    const revealTargets = [...document.querySelectorAll('[data-reveal]')];

      if (reducedMotion.matches) {
        revealTargets.forEach((node) => node.classList.add('is-visible'));
        stopHeroShapeDrift();
      } else {
        startHeroShapeDrift();
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.22,
          rootMargin: '0px 0px -10% 0px',
        },
      );

      revealTargets.forEach((node) => revealObserver.observe(node));
    }

    const syncHeroState = () => {
      const threshold = Math.min(window.innerHeight * 0.35, 300);
      document.body.classList.toggle('v2-hero-collapsed', window.scrollY > threshold);
    };

    const onScroll = () => {
      syncHeroState();
      nudgeHeroWobble();
      syncCardOrbits();
    };

    startHeroShapeDrift();
    buildCardOrbitRows();
    syncHeroState();
    syncCardOrbits();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      buildCardOrbitRows();
      syncHeroState();
      syncCardOrbits();
    });

    if (typeof reducedMotion.addEventListener === 'function') {
      reducedMotion.addEventListener('change', () => {
        if (reducedMotion.matches) {
          resetHeroWobble();
          cardOrbitTargets.forEach((card) => stopCardHoverOrbit(card));
          stopHeroShapeDrift();
          if (heroBg instanceof HTMLElement) {
            heroBg.style.removeProperty('--hero-bg-scroll');
          }
          if (heroShapes.length) {
            heroShapes.forEach((shape) => {
              if (shape instanceof HTMLElement) {
                shape.style.removeProperty('--shape-scroll-offset');
                shape.style.removeProperty('--shape-parallax-y');
                shape.style.removeProperty('--shape-jitter-x');
                shape.style.removeProperty('--shape-jitter-y');
                shape.style.removeProperty('--shape-jitter-rotate');
              }
            });
          }
          heroShapeLag = 0;
        } else {
          startHeroShapeDrift();
        }

        syncCardOrbits();
      });
    }
  </script>
</BaseLayout>

