  }

  .v2-chip:nth-child(3) {
    animation-delay: 260ms;
  }

  .v2-chip:nth-child(4) {
    animation-delay: 330ms;
  }

  .v2-hero-visual {
    order: -1;
    display: grid;
    place-items: center;
    width: 100%;
  }

  .v2-logo-fluid {
    --hero-scroll-bob: 0px;
    display: grid;
    place-items: center;
    width: min(100%, 32rem);
    margin-inline: auto;
    transform: translate3d(0, var(--hero-scroll-bob), 0);
    will-change: transform;
  }

  .v2-logo-orb {
    position: relative;
    width: min(100%, 32rem);
    aspect-ratio: 1;
    border-radius: 28%;
    display: grid;
    place-items: center;
    border: 1px solid rgba(157, 181, 214, 0.34);
    background:
      radial-gradient(circle at 30% 18%, rgba(224, 122, 47, 0.16), transparent 50%),
      radial-gradient(circle at 72% 72%, rgba(31, 58, 95, 0.34), transparent 64%),
      rgba(13, 24, 41, 0.86);
    box-shadow:
      0 26px 48px rgba(2, 4, 10, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.09),
      0 0 calc(70px * var(--motion-glow)) rgba(31, 58, 95, 0.25);
    animation: v2-logo-drift calc(12s / var(--motion-rate)) ease-in-out infinite;
    transition:
      opacity calc(380ms / var(--motion-rate)) ease,
      transform calc(380ms / var(--motion-rate)) ease;
    will-change: transform;
  }

  body.v2-hero-collapsed .v2-logo-orb {
    opacity: 0.16;
    transform: translateY(calc(-44px * var(--motion-amp))) scale(0.84);
  }

  .v2-hero-logo {
    width: min(84%, 24rem);
    height: auto;
    filter: drop-shadow(0 10px 22px rgba(2, 4, 8, 0.45));
    animation: v2-hero-float calc(7s / var(--motion-rate)) ease-in-out infinite;
    will-change: transform;
    z-index: 2;
  }

  .v2-orbit {
    position: absolute;
    border: 1px solid rgba(172, 195, 228, 0.28);
    border-radius: 50%;
    pointer-events: none;
  }

  .v2-orbit-a {
    width: 108%;
    height: 108%;
    animation: v2-spin calc(26s / var(--motion-rate)) linear infinite;
  }

  .v2-orbit-b {
    width: 82%;
    height: 82%;
    transform: rotate(28deg);
    border-style: dashed;
    animation: v2-spin-reverse calc(18s / var(--motion-rate)) linear infinite;
  }

  .v2-orbit-c {
    width: 126%;
    height: 126%;
    border-color: rgba(224, 122, 47, 0.32);
    animation: v2-spin calc(36s / var(--motion-rate)) linear infinite;
  }

  .v2-section {
    padding-block: clamp(3.5rem, 9vw, 6.7rem);
  }

  .v2-section-tint {
    background: linear-gradient(180deg, rgba(19, 34, 58, 0.26) 0%, rgba(19, 34, 58, 0.08) 100%);
    border-block: 1px solid rgba(142, 163, 197, 0.24);
  }

  .v2-section-head {
    margin-bottom: clamp(1.7rem, 4vw, 2.6rem);
    max-width: 70ch;
  }

  .v2-section-head h2 {
    margin: 0.6rem 0 0.84rem;
    font-size: var(--fluid-h2);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .v2-section-head p {
    margin: 0;
    color: var(--text-sub);
    font-size: var(--fluid-body);
    line-height: 1.7;
    max-width: 62ch;
  }

  .v2-grid {
    display: grid;
    gap: clamp(0.95rem, 2.2vw, 1.35rem);
  }

  .v2-grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .v2-card {
    --card-orbit-x: 50%;
    --card-orbit-y: 100%;
    --card-orbit-progress: 0;
    --card-orbit-angle: 0deg;
    --card-hover-sweep: 0deg;
    position: relative;
    padding: clamp(1.1rem, 2.3vw, 1.45rem);
    border-radius: var(--radius-card);
    border: 1px solid rgba(182, 203, 232, 0.2);
    background:
      radial-gradient(circle at 18% 10%, rgba(255, 255, 255, 0.15), transparent 36%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.015) 24%, rgba(255, 255, 255, 0) 100%),
      linear-gradient(165deg, rgba(24, 42, 68, 0.82) 0%, rgba(14, 24, 40, 0.92) 55%, rgba(9, 16, 28, 0.96) 100%);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    box-shadow:
      0 16px 34px rgba(2, 5, 11, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      inset 0 -18px 32px rgba(5, 10, 18, 0.16);
    transition:
      transform calc(340ms / var(--motion-rate)) cubic-bezier(0.2, 1, 0.22, 1),
      border-color calc(260ms / var(--motion-rate)) ease,
      box-shadow calc(280ms / var(--motion-rate)) ease,
      background calc(280ms / var(--motion-rate)) ease;
    overflow: hidden;
    isolation: isolate;
  }

  .v2-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 1;
    display: none;
    pointer-events: none;
  }

  .v2-card::after {
    content: '';
    position: absolute;
    inset: auto 12% 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(31, 58, 95, 0.06), rgba(224, 122, 47, 0.74), rgba(31, 58, 95, 0.06));
    opacity: 0.88;
    transform: translate3d(0, 0, 0);
    transform-origin: center;
    transition:
      opacity calc(240ms / var(--motion-rate)) ease,
      filter calc(260ms / var(--motion-rate)) ease;
    filter: blur(0.4px);
    pointer-events: none;
  }

  @supports ((-webkit-mask-composite: xor) or (mask-composite: exclude)) {
    .v2-card::before {
      display: block;
      padding: 3px;
      border-radius: inherit;
      background: conic-gradient(
        from var(--card-orbit-angle),
        rgba(255, 214, 168, 0.94) 0deg,
        rgba(255, 186, 121, 0.98) var(--card-hover-sweep),
        rgba(255, 160, 94, 0) calc(var(--card-hover-sweep) + 2deg),
        rgba(255, 160, 94, 0) 360deg
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: exclude;
      filter:
        blur(0.52px)
        drop-shadow(0 0 calc(38px * var(--motion-glow)) rgba(255, 186, 120, 0.56))
        drop-shadow(0 0 calc(62px * var(--motion-glow)) rgba(224, 122, 47, 0.4));
      transition: filter calc(180ms / var(--motion-rate)) ease;
      will-change: filter;
    }

    .v2-card::after {
      inset: 0;
      height: auto;
      padding: 3px;
      border-radius: inherit;
      background: radial-gradient(
        circle 10.4rem at var(--card-orbit-x) var(--card-orbit-y),
        rgba(255, 214, 170, 0.98) 0%,
        rgba(255, 181, 118, 0.9) 26%,
        rgba(255, 154, 87, 0.56) 46%,
        rgba(224, 122, 47, 0.2) 64%,
        rgba(224, 122, 47, 0) 86%
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: exclude;
      filter:
        blur(0.28px)
        drop-shadow(0 0 calc(30px * var(--motion-glow)) rgba(255, 176, 110, 0.56))
        drop-shadow(0 0 calc(48px * var(--motion-glow)) rgba(224, 122, 47, 0.4));
      transition:
        filter calc(300ms / var(--motion-rate)) ease,
        opacity calc(220ms / var(--motion-rate)) ease;
    }
  }

  .v2-card > * {
    position: relative;
    z-index: 1;
  }

  .v2-card:hover,
  .v2-card:focus-within {
    transform: translateY(calc(-8px * var(--motion-lift)));
    border-color: rgba(239, 154, 88, 0.54);
    box-shadow:
      0 22px 44px rgba(1, 6, 12, 0.44),
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      inset 0 -18px 32px rgba(5, 10, 18, 0.18);
  }

  .v2-card:hover::after,
  .v2-card:focus-within::after {
    opacity: 1;
    filter:
      blur(0.2px)
      drop-shadow(0 0 calc(30px * var(--motion-glow)) rgba(255, 170, 99, 0.58))
      drop-shadow(0 0 calc(46px * var(--motion-glow)) rgba(224, 122, 47, 0.42));
  }

  .v2-card h3 {
    margin: 0;
    font-size: var(--fluid-h3);
    line-height: 1.28;
    letter-spacing: -0.01em;
  }

  .v2-card p {
    margin: 0.74rem 0 0;
    color: var(--text-sub);
    line-height: 1.65;
    font-size: 0.98rem;
  }

  .v2-card-tag {
    margin: 0;
    display: inline-block;
    border-radius: 999px;
    padding: 0.3rem 0.68rem;
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    font-weight: 600;
    color: #ffd6b8;
    background: rgba(224, 122, 47, 0.2);
  }

  .v2-impact {
    color: #f8dfcf;
  }

  .v2-solution-card ul,
  .v2-story-copy ul {
    margin: 0.95rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.56rem;
  }

  .v2-solution-card li,
  .v2-story-copy li {
    position: relative;
    padding-left: 1.15rem;
    color: var(--text-sub);
    font-size: 0.95rem;
    line-height: 1.56;
  }

  .v2-solution-card li::before,
  .v2-story-copy li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.57rem;
    width: 0.52rem;
    height: 0.52rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px rgba(224, 122, 47, 0.44);
  }

  .v2-inline-link {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    color: #ffd7bc;
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    transition: color calc(220ms / var(--motion-rate)) ease;
  }

  .v2-inline-link:hover,
  .v2-inline-link:focus-visible {
    color: #ffe9d8;
  }

  .v2-steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.95rem, 2.1vw, 1.2rem);
  }

  .v2-step {
    padding: clamp(1rem, 2.2vw, 1.35rem);
    border-radius: var(--radius-card);
    border: 1px solid rgba(157, 181, 214, 0.2);
    background: linear-gradient(180deg, rgba(16, 28, 48, 0.9) 0%, rgba(13, 22, 38, 0.92) 100%);
    box-shadow: 0 8px 22px rgba(3, 8, 15, 0.34);
    transition:
      transform calc(320ms / var(--motion-rate)) cubic-bezier(0.2, 1, 0.22, 1),
      border-color calc(260ms / var(--motion-rate)) ease;
  }

  .v2-step:hover,
  .v2-step:focus-within {
    transform: translateY(calc(-6px * var(--motion-lift)));
    border-color: rgba(224, 122, 47, 0.5);
  }

  .v2-step-no {
    margin: 0;
    color: #ffd6b6;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .v2-step h3 {
    margin: 0.52rem 0 0;
    font-size: 1.15rem;
  }

  .v2-step p {
    margin: 0.72rem 0 0;
    color: var(--text-sub);
    line-height: 1.6;
    font-size: 0.96rem;
  }

  .v2-story-list {
    display: grid;
    gap: clamp(0.95rem, 2.2vw, 1.3rem);
  }

  .v2-story {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1rem, 2.4vw, 1.5rem);
    padding: clamp(1rem, 2.2vw, 1.3rem);
    border-radius: calc(var(--radius-card) + 0.25rem);
    border: 1px solid rgba(157, 181, 214, 0.22);
    background: linear-gradient(180deg, rgba(14, 24, 41, 0.88) 0%, rgba(10, 18, 31, 0.92) 100%);
    box-shadow: 0 16px 36px rgba(2, 6, 12, 0.38);
  }

  .v2-story-frame {
    position: relative;
    border-radius: 1rem;
    min-height: 250px;
    border: 1px solid rgba(173, 197, 230, 0.23);
    overflow: clip;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.42rem;
    padding: 1rem;
    background:
      radial-gradient(circle at 12% 18%, rgba(224, 122, 47, 0.35), transparent 45%),
      radial-gradient(circle at 86% 80%, rgba(31, 58, 95, 0.6), transparent 58%),
      linear-gradient(160deg, rgba(11, 20, 35, 0.96), rgba(18, 31, 52, 0.94));
    animation: v2-frame-drift calc(9.8s / var(--motion-rate)) ease-in-out infinite;
  }

  .v2-story:nth-child(even) .v2-story-frame {
    animation-duration: calc(12.8s / var(--motion-rate));
    animation-direction: reverse;
  }

  .v2-story-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(112deg, transparent 20%, rgba(255, 255, 255, 0.24) 48%, transparent 82%);
    transform: translateX(-125%);
    animation: v2-sheen calc(7.6s / var(--motion-rate)) ease-in-out infinite;
    pointer-events: none;
  }

  .v2-frame-eyebrow {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(249, 212, 182, 0.9);
    position: relative;
    z-index: 1;
  }

  .v2-frame-headline {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.18;
    position: relative;
    z-index: 1;
  }

  .v2-frame-caption {
    margin: 0;
    color: var(--text-sub);
    font-size: 0.88rem;
    line-height: 1.52;
    position: relative;
    z-index: 1;
  }

  .v2-story-copy h3 {
    margin: 0;
    font-size: clamp(1.15rem, 2.4vw, 1.48rem);
    line-height: 1.22;
  }

  .v2-story-lead {
    margin: 0.72rem 0 0;
    color: var(--text-sub);
    line-height: 1.66;
    max-width: 62ch;
  }

  .v2-faq-shell {
    display: grid;
    gap: clamp(1.1rem, 2.6vw, 1.5rem);
  }

  .v2-faq-list {
    display: grid;
    gap: 0.72rem;
  }

  .v2-faq-item {
    border-radius: 1rem;
    border: 1px solid rgba(157, 181, 214, 0.22);
    background: rgba(14, 24, 41, 0.75);
    overflow: hidden;
  }

  .v2-faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 1rem 1.1rem;
    font-weight: 600;
    line-height: 1.45;
    position: relative;
    color: var(--text-main);
  }

  .v2-faq-item summary::-webkit-details-marker {
    display: none;
  }

  .v2-faq-item summary::after {
    content: '+';
    position: absolute;
    right: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent);
    font-size: 1.14rem;
    transition: transform calc(240ms / var(--motion-rate)) ease;
  }

  .v2-faq-item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .v2-faq-item p {
    margin: 0;
    padding: 0 1.1rem 1rem;
    color: var(--text-sub);
    line-height: 1.65;
  }

  .v2-final {
    padding-top: clamp(2.8rem, 7vw, 5.2rem);
  }

  .v2-final-card {
    border-radius: calc(var(--radius-card) + 0.6rem);
    border: 1px solid rgba(224, 122, 47, 0.34);
    padding: clamp(1.35rem, 3vw, 2.3rem);
    background:
      radial-gradient(circle at 85% 15%, rgba(224, 122, 47, 0.28), transparent 45%),
      linear-gradient(150deg, rgba(15, 28, 46, 0.95), rgba(11, 19, 33, 0.98));
    box-shadow:
      0 20px 46px rgba(2, 6, 12, 0.4),
      0 0 calc(56px * var(--motion-glow)) rgba(224, 122, 47, 0.2);
  }

  .v2-final-card h2 {
    margin: 0.6rem 0 0;
    font-size: clamp(1.6rem, 4.5vw, 2.85rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .v2-final-text,
  .v2-final-note {
    margin: 0.9rem 0 0;
    color: var(--text-sub);
    line-height: 1.7;
    max-width: 68ch;
  }

  .v2-final-note {
    color: rgba(247, 224, 206, 0.9);
    font-size: 0.95rem;
  }

  .v2-footer {
    padding-block: clamp(2.6rem, 7vw, 4.2rem) clamp(2.4rem, 6.5vw, 3.5rem);
  }

  .v2-footer-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.1rem, 2.4vw, 1.6rem);
    border-top: 1px solid rgba(157, 181, 214, 0.22);
    padding-top: clamp(1.2rem, 2.6vw, 1.9rem);
  }

  .v2-footer-block {
    display: grid;
    gap: 0.42rem;
  }

  .v2-footer-logo {
    width: clamp(9.6rem, 18vw, 12rem);
    height: auto;
    margin-bottom: 0.35rem;
  }

  .v2-footer-block p,
  .v2-footer-block a {
    margin: 0;
    color: var(--text-sub);
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .v2-footer-legal {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.68rem;
  }

  .v2-footer-legal a,
  .v2-footer-block a:hover,
  .v2-footer-block a:focus-visible {
    color: var(--text-main);
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(calc(26px * var(--motion-amp)));
    filter: blur(6px);
    transition:
      opacity calc(640ms / var(--motion-rate)) ease,
      transform calc(720ms / var(--motion-rate)) cubic-bezier(0.2, 1, 0.22, 1),
      filter calc(640ms / var(--motion-rate)) ease;
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
    filter: none;
  }

  @keyframes v2-geometric-shape-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes v2-geometric-shape-float {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-18px) scale(1.01);
    }
  }

  @keyframes v2-geometric-shape-shimmer {
    0%,
    100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes v2-word-rise {
    from {
      opacity: 0;
      transform: translateY(calc(28px * var(--motion-amp)));
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: blur(0);
    }
  }

  @keyframes v2-chip-in {
    from {
      opacity: 0;
      transform: translateY(calc(14px * var(--motion-amp)));
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes v2-logo-drift {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(calc(-12px * var(--motion-amp))) rotate(0.55deg);
    }
  }

  @keyframes v2-hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(calc(-10px * var(--motion-amp)));
    }
  }

  @keyframes v2-sheen {
    0% {
      transform: translateX(-125%);
    }
    48%,
    100% {
      transform: translateX(125%);
    }
  }

  @keyframes v2-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes v2-spin-reverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }

  @keyframes v2-frame-drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(calc(7px * var(--motion-amp)), calc(-5px * var(--motion-amp)), 0);
    }
  }

  @media (max-width: 1080px) {
    .v2-grid-3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .v2-story {
      grid-template-columns: 1fr;
    }

    .v2-story-frame {
      min-height: 220px;
    }
  }

  @media (max-width: 900px) {
    .v2-logo-orb {
      width: min(100%, 22rem);
    }

    .v2-nav-links {
      display: none;
    }

    .v2-steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .v2-nav {
      padding: 0.62rem 0.72rem;
      width: calc(100% - 0.9rem);
    }

    .v2-brand-link {
      width: 9rem;
    }

    .v2-nav-cta {
      padding-inline: 0.92rem;
      font-size: 0.84rem;
    }

    .v2-grid-3,
    .v2-footer-grid {
      grid-template-columns: 1fr;
    }

    .v2-hero {
      padding-top: 3.8rem;
    }

    .v2-chip-list {
      gap: 0.52rem;
    }

    .v2-chip {
      font-size: 0.76rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
