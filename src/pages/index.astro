---
/**
 * index.astro - LexIT Homepage
 *
 * Structure follows Board Document pattern:
 * 1. Opening Statement (Hero) - Clear value proposition
 * 2. Leistungsübersicht - Three service pillars
 * 3. Positionierungsaussage - Strategic positioning with X-Intervention
 * 4. Zielgruppen-Qualifikation - Target audience clarity
 *
 * Design Decisions:
 * - X-Intervention placed only once (in Positionierungsaussage)
 * - No decorative elements, pure content hierarchy
 * - Generous whitespace to create breathing room
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />

  <main>
    <!-- =================================================================
         1. Opening Statement (Hero)
         Design: Trust Blue background, prominent X logo, white text
         Two variants that alternate randomly on page load
         ================================================================= -->
    <section class="bg-trust-blue pt-[40px] pb-[60px] md:pt-[60px] md:pb-[80px] text-white">
      <div class="mx-auto max-w-[800px] px-6 text-center md:px-8">
        <!-- Centered Logo above text -->
        <img
          src="/Lexit_X_logo_dark_bg.png"
          alt="LexIT Executive Governance"
          class="mx-auto mb-8 w-[220px] md:w-[385px] lg:w-[440px]"
        />
        <!-- Variant A -->
        <div id="hero-a" class="hero-variant">
          <h1 class="text-[36px] md:text-[48px] font-semibold leading-[1.1] tracking-[-0.02em]">
            Regulatorik ist komplex. LexIT macht sie handhabbar.
          </h1>
          <p class="mt-6 text-[16px] md:text-[18px] leading-[1.6] text-white/80">
            NIS2, DORA, AI Act, DSGVO – verständlich, pragmatisch und in Ihre Abläufe integriert.
          </p>
        </div>
        <!-- Variant B -->
        <div id="hero-b" class="hero-variant hidden">
          <h1 class="text-[36px] md:text-[48px] font-semibold leading-[1.1] tracking-[-0.02em]">
            Compliance, Governance und IT‑Services, die im Alltag funktionieren.
          </h1>
          <p class="mt-6 text-[16px] md:text-[18px] leading-[1.6] text-white/80">
            Klare Entscheidungen, saubere Strukturen, messbarer Nutzen – ohne Beraterdeutsch.
          </p>
        </div>
      </div>
    </section>
    <script>
      if (Math.random() > 0.5) {
        document.getElementById('hero-a')?.classList.add('hidden');
        document.getElementById('hero-b')?.classList.remove('hidden');
      }
    </script>

    <!-- =================================================================
         2. Leistungsübersicht
         Design: 3 cards with off-white background and amber top border
         ================================================================= -->
    <section id="leistungen" class="pt-[80px] pb-[100px] md:pt-[100px] md:pb-[140px] bg-white">
      <div class="mx-auto max-w-6xl px-6 md:px-8">
        <div class="grid gap-8 md:grid-cols-3 md:gap-6">

          <!-- IT-Compliance Card -->
          <a href="/leistungen/it-compliance" class="block bg-off-white border-t-4 border-controlled-amber p-8 md:p-10 hover:border-trust-blue transition-colors group">
            <h2 class="text-h2-mobile md:text-h2 mb-4 group-hover:text-controlled-amber transition-colors">
              IT-Compliance
            </h2>
            <p class="text-body-mobile md:text-body">
              LexIT übersetzt Regulatorik in klare, machbare Schritte. NIS2, DORA,
              AI Act, DSGVO – eingebettet in Ihre Prozesse, ohne Papierstapel.
            </p>
            <span class="inline-block mt-4 text-meta text-trust-blue group-hover:text-controlled-amber transition-colors">
              Mehr erfahren →
            </span>
          </a>

          <!-- IT-Governance Card -->
          <a href="/leistungen/it-governance" class="block bg-off-white border-t-4 border-controlled-amber p-8 md:p-10 hover:border-trust-blue transition-colors group">
            <h2 class="text-h2-mobile md:text-h2 mb-4 group-hover:text-controlled-amber transition-colors">
              IT-Governance
            </h2>
            <p class="text-body-mobile md:text-body">
              Rollen, Risiken, Entscheidungen – so, dass jeder weiß, was zu tun ist.
              Governance, die im Alltag trägt und im Audit besteht.
            </p>
            <span class="inline-block mt-4 text-meta text-trust-blue group-hover:text-controlled-amber transition-colors">
              Mehr erfahren →
            </span>
          </a>

          <!-- Produktdesign Card -->
          <a href="/leistungen/produktdesign" class="block bg-off-white border-t-4 border-controlled-amber p-8 md:p-10 hover:border-trust-blue transition-colors group">
            <h2 class="text-h2-mobile md:text-h2 mb-4 group-hover:text-controlled-amber transition-colors">
              Produktdesign
            </h2>
            <p class="text-body-mobile md:text-body">
              LexIT definiert USP und Kundennutzen Ihrer IT‑Services. Von der Idee
              über SLAs bis zum Vertrag – klar, verständlich, verkaufbar.
            </p>
            <span class="inline-block mt-4 text-meta text-trust-blue group-hover:text-controlled-amber transition-colors">
              Mehr erfahren →
            </span>
          </a>

        </div>
      </div>
    </section>

    <!-- =================================================================
         3. Positionierungsaussage
         Design: Trust Blue background, white text for readability
         ================================================================= -->
    <section id="ansatz" class="bg-trust-blue text-white">
      <div class="mx-auto max-w-[700px] px-[40px] py-[60px] text-center md:px-[60px] md:py-[80px]">
        <p class="text-[16px] md:text-[18px] leading-[1.6]">
          Regulatorik verschwindet nicht. Die Frage ist, ob sie Sie bremst
          oder strukturiert voranbringt. Mit 15 Jahren Konzernerfahrung in
          ISO-Zertifizierungen, ESG-Frameworks und IT-Governance zeigen, was in der
          Praxis trägt – ohne Folienfriedhöfe.
        </p>
      </div>
    </section>

    <!-- =================================================================
         4. Profil
         Design: Two-column layout with credentials
         ================================================================= -->
    <section id="ueber" class="pt-[80px] pb-[100px] md:pt-[100px] md:pb-[140px] bg-white">
      <div class="mx-auto max-w-5xl px-6 md:px-8">
        <div class="grid gap-12 md:grid-cols-2 md:gap-16">

          <!-- Left Column: Personal intro -->
          <div>
            <h2 class="text-h2-mobile md:text-h2 mb-6">
              Profil
            </h2>
            <div class="space-y-4 text-body-mobile md:text-body">
              <p>
                Matthias König ist Jurist, IT‑Spezialist und seit über zehn Jahren an der
                Schnittstelle von Recht, Technologie und Unternehmensführung tätig.
              </p>
              <p>
                Praxisbezug: Als Manager Legal & Compliance bei einem internationalen
                IT‑Dienstleister wurden Teams geführt, ISO‑Zertifizierungen begleitet,
                ESG‑Programme aufgebaut und als Interim‑CISO die Informationssicherheit verantwortet.
              </p>
              <p>
                Regulierung muss nicht lähmen. Richtig umgesetzt schafft sie Struktur,
                reduziert Risiken und stärkt Vertrauen.
              </p>
            </div>
          </div>

          <!-- Right Column: Credentials -->
          <div class="space-y-8">
            <!-- Experience -->
            <div>
              <h3 class="text-h3 text-trust-blue mb-4">Erfahrung</h3>
              <ul class="space-y-2 text-body-mobile md:text-body">
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>10+ Jahre Konzern: Legal, Compliance, IT-Governance, CISO</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>ISO 27001, ISO 9001, ISO 14001 – Implementierung & Audits</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>ESG/CSR-Strategieentwicklung auf Gruppenebene</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>Service Level Management & ITIL-Implementierung</span>
                </li>
              </ul>
            </div>

            <!-- Credentials -->
            <div>
              <h3 class="text-h3 text-trust-blue mb-4">Qualifikationen</h3>
              <ul class="space-y-2 text-body-mobile md:text-body">
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>Mag. iur. (Rechtswissenschaften) & M.A. IT-Law and Management</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>ITIL v3 Expert & ITIL 4 Managing Professional</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>Certified Compliance Officer (Austrian Standards)</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-controlled-amber mt-1">→</span>
                  <span>Dozent: Donau-Universität Krems, FH Burgenland</span>
                </li>
              </ul>
            </div>

            <!-- Recognition -->
            <div>
              <h3 class="text-h3 text-trust-blue mb-4">Auszeichnungen</h3>
              <p class="text-body-mobile md:text-body">
                <span class="font-semibold">Legal 500 GC Powerlist</span> – Austria 2022 & 2024<br>
                <span class="text-slate text-meta">Auszeichnung für die einflussreichsten In-House-Juristen Österreichs</span>
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- =================================================================
         5. Zielgruppen-Qualifikation
         Design: Meta typography, slate color, centered narrow width
         ================================================================= -->
    <section class="pt-[60px] pb-[80px] md:pt-[80px] md:pb-[100px] bg-off-white">
      <div class="mx-auto max-w-[600px] px-6 text-center md:px-8">
        <p class="text-meta text-slate">
          Für Geschäftsführung, IT‑Leitung und Compliance in Unternehmen, die
          Regulatorik ernst nehmen – aber pragmatisch umsetzen wollen.
          Österreich und Deutschland.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
