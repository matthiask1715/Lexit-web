---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Formspree endpoint - replace with your form ID
const FORMSPREE_ID = "YOUR_FORMSPREE_ID";
---

<BaseLayout title="Kontakt – LexIT Executive Governance">
  <Header />

  <main class="pt-[60px] pb-[100px] md:pt-[80px] md:pb-[140px]">
    <div class="mx-auto max-w-[600px] px-6 md:px-8">
      <h1 class="text-[36px] md:text-[48px] font-semibold leading-[1.1] tracking-[-0.02em] text-trust-blue mb-6">
        Kontakt
      </h1>
      <p class="text-body-mobile md:text-body text-slate mb-12">
        Sie haben Fragen zu IT-Compliance, Governance oder Produktdesign?
        Schreiben Sie mir – ich melde mich innerhalb von 24 Stunden.
      </p>

      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="space-y-6"
      >
        <!-- Honeypot field for spam protection -->
        <input type="text" name="_gotcha" class="hidden" />

        <!-- Name -->
        <div>
          <label for="name" class="block text-meta text-ink mb-2">
            Name <span class="text-controlled-amber">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 border border-line-grey rounded-sm
                   text-body-mobile md:text-body text-ink
                   focus:outline-none focus:border-trust-blue focus:ring-1 focus:ring-trust-blue
                   transition-colors"
            placeholder="Ihr Name"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-meta text-ink mb-2">
            E-Mail <span class="text-controlled-amber">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 border border-line-grey rounded-sm
                   text-body-mobile md:text-body text-ink
                   focus:outline-none focus:border-trust-blue focus:ring-1 focus:ring-trust-blue
                   transition-colors"
            placeholder="ihre@email.at"
          />
        </div>

        <!-- Company (optional) -->
        <div>
          <label for="company" class="block text-meta text-ink mb-2">
            Unternehmen
          </label>
          <input
            type="text"
            id="company"
            name="company"
            autocomplete="organization"
            class="w-full px-4 py-3 border border-line-grey rounded-sm
                   text-body-mobile md:text-body text-ink
                   focus:outline-none focus:border-trust-blue focus:ring-1 focus:ring-trust-blue
                   transition-colors"
            placeholder="Ihr Unternehmen (optional)"
          />
        </div>

        <!-- Subject -->
        <div>
          <label for="subject" class="block text-meta text-ink mb-2">
            Betreff <span class="text-controlled-amber">*</span>
          </label>
          <select
            id="subject"
            name="subject"
            required
            class="w-full px-4 py-3 border border-line-grey rounded-sm
                   text-body-mobile md:text-body text-ink bg-white
                   focus:outline-none focus:border-trust-blue focus:ring-1 focus:ring-trust-blue
                   transition-colors"
          >
            <option value="">Bitte wählen...</option>
            <option value="IT-Compliance">IT-Compliance (NIS2, DORA, AI Act)</option>
            <option value="IT-Governance">IT-Governance</option>
            <option value="Produktdesign">Produktdesign für IT-Services</option>
            <option value="Allgemeine Anfrage">Allgemeine Anfrage</option>
          </select>
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-meta text-ink mb-2">
            Nachricht <span class="text-controlled-amber">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 border border-line-grey rounded-sm
                   text-body-mobile md:text-body text-ink
                   focus:outline-none focus:border-trust-blue focus:ring-1 focus:ring-trust-blue
                   transition-colors resize-y"
            placeholder="Wie kann ich Ihnen helfen?"
          ></textarea>
        </div>

        <!-- Privacy notice -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="mt-1 w-4 h-4 text-trust-blue border-line-grey rounded
                   focus:ring-trust-blue"
          />
          <label for="privacy" class="text-meta text-slate">
            Ich habe die <a href="/datenschutz" class="text-trust-blue hover:text-controlled-amber underline">Datenschutzerklärung</a> gelesen und bin mit der Verarbeitung meiner Daten einverstanden. <span class="text-controlled-amber">*</span>
          </label>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full md:w-auto px-8 py-4 bg-trust-blue text-white font-semibold
                 hover:bg-controlled-amber transition-colors
                 focus:outline-none focus:ring-2 focus:ring-trust-blue focus:ring-offset-2"
        >
          Nachricht senden
        </button>
      </form>

      <!-- Alternative contact -->
      <div class="mt-16 pt-10 border-t border-line-grey">
        <p class="text-meta text-slate">
          Oder direkt anrufen:
          <a href="#" class="contact-phone text-trust-blue hover:text-controlled-amber font-semibold">
            0660 / 60 88 762
          </a>
        </p>
        <p class="text-meta text-slate mt-2">
          Graz, Steiermark, Österreich
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Obfuscate phone link
  const p = ['0660', '60', '88', '762'].join('');
  document.querySelectorAll('.contact-phone').forEach(el => {
    el.setAttribute('href', 'tel:+43' + p);
  });
</script>
