---
/**
 * Footer.astro
 *
 * Two-column footer: Company info left, Contact/Legal right.
 * Design: Subtle border-top, meta typography, professional spacing.
 *
 * Design Decision: Using border-top as visual separator,
 * consistent with "board document" aesthetic.
 */
---

<footer class="bg-trust-blue">
  <div class="mx-auto max-w-6xl px-6 py-[60px] md:px-8">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">

      <!-- Left Column: Logo & Company -->
      <div class="flex flex-col gap-4">
        <img
          src="/Lexit_X_only_dark_bg.png"
          alt="LexIT"
          width="180"
          height="auto"
          class="h-auto w-[180px]"
        />
        <p class="text-meta !text-white/70">
          Graz, Steiermark, Österreich
        </p>
      </div>

      <!-- Right Column: Contact & Legal -->
      <div class="flex flex-col gap-6 md:items-end md:text-right">
        <!-- Contact -->
        <div class="text-meta">
          <a href="/kontakt" class="!text-white hover:!text-controlled-amber font-semibold">
            Kontakt aufnehmen →
          </a>
          <p class="mt-2 !text-white/70">
            <a href="#" class="contact-phone !text-white/70 hover:!text-controlled-amber">
              0660 / 60 88 762
            </a>
          </p>
        </div>

        <!-- Legal Links -->
        <div class="text-meta !text-white/70">
          <a href="/impressum" class="!text-white/70 hover:!text-controlled-amber">Impressum</a>
          <span class="mx-2 text-white/30">|</span>
          <a href="/datenschutz" class="!text-white/70 hover:!text-controlled-amber">Datenschutz</a>
        </div>
      </div>

    </div>
  </div>
</footer>

<script>
  // Phone obfuscation - decoded client-side
  const p = ['0660', '60', '88', '762'].join('');
  document.querySelectorAll('.contact-phone').forEach(el => {
    el.setAttribute('href', 'tel:+43' + p);
  });
</script>
